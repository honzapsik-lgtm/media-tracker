generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model media_stats {
  id                String   @id
  media_type        String
  community_average Decimal? @default(0) @db.Decimal
  total_ratings     Int?     @default(0)
}

model user_badges {
  user_id     String    @db.Uuid
  badge_id    String
  unlocked_at DateTime? @default(now()) @db.Timestamptz(6)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, badge_id])
}

model user_ranked_lists {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  media_id      String
  media_type    String
  rank_position Int
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_ratings {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  media_id        String
  media_title     String?
  media_image     String?
  score           Int
  review_text     String?
  username        String?
  avatar_url      String?
  criteria_scores Json?    @default("{}")
  is_deep_review  Boolean? @default(false)
  rank_position   Int?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  users           users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_id])
}

model user_watchlist {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  media_id    String
  media_title String?
  media_image String?
  media_type  String?
  status      String?   @default("plan_to_watch")
  added_at    DateTime? @default(now()) @db.Timestamptz(6)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_id])
}

model users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  
  // Relations to the new NextAuth tables and your existing tables
  accounts      Account[]
  sessions      Session[]
  ratings       user_ratings[]
  watchlist     user_watchlist[]
  badges        user_badges[]
  ranked_lists  user_ranked_lists[]
}

// 2. NextAuth Required Tables (OAuth Accounts & Sessions)
model Account {
  id                 String  @id @default(cuid())
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
