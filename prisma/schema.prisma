generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MediaStats {
  id                String   @id
  media_type        String
  community_average Decimal? @default(0) @db.Decimal
  total_ratings     Int?     @default(0)

  @@map("media_stats")
}

model UserBadge {
  user_id     String    @db.Uuid
  badge_id    String
  unlocked_at DateTime? @default(now()) @db.Timestamptz(6)
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, badge_id])
  @@map("user_badges")
}

model UserRankedList {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  media_id      String
  media_type    String
  rank_position Int
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  user          User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_id])
  @@map("user_ranked_lists")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model UserRating {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String   @db.Uuid
  media_id        String
  media_title     String?
  media_image     String?
  score           Int
  review_text     String?
  username        String?
  avatar_url      String?
  criteria_scores Json?    @default("{}")
  is_deep_review  Boolean? @default(false)
  rank_position   Int?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_id])
  @@map("user_ratings")
}

model UserWatchlist {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  media_id    String
  media_title String?
  media_image String?
  media_type  String?
  status      String?   @default("plan_to_watch")
  added_at    DateTime? @default(now()) @db.Timestamptz(6)
  user        User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_id])
  @@map("user_watchlist")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  realName      String?
  stateRegion   String?
  country       String?
  showcaseBadges String[] @default([])
  role          String    @default("user")
  
  // Relations to the new NextAuth tables and your existing tables
  accounts      Account[]
  sessions      Session[]
  ratings       UserRating[]
  watchlist     UserWatchlist[]
  badges        UserBadge[]
  ranked_lists  UserRankedList[]
  stats_cache   UserStatsCache[]

  @@map("users")
}

// 2. NextAuth Required Tables (OAuth Accounts & Sessions)
model Account {
  id                 String  @id @default(cuid())
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApiCache {
  id         String   @id
  provider   String
  data       Json
  created_at DateTime @default(now())
  expires_at DateTime
}

model UserStatsCache {
  user_id    String   @db.Uuid
  media_type String
  stats_json Json
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, media_type])
}

model BackgroundJob {
  id           String    @id @default(uuid())
  type         String
  payload      Json
  status       String    @default("pending")
  dedupe_key   String?
  attempts     Int       @default(0)
  max_attempts Int       @default(3)
  run_at       DateTime  @default(now())
  locked_at    DateTime?
  locked_by    String?
  last_error   String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  processed_at DateTime?

  @@index([status, run_at])
  @@index([type, status])
  @@index([locked_at])
  @@index([dedupe_key])
  @@index([created_at])
}

model SystemLog {
  id           String   @id @default(cuid())
  level        String
  event        String
  message      String?
  requestId    String?
  userId       String?
  mediaId      String?
  mediaType    String?
  jobId        String?
  durationMs   Int?
  metadata     Json?
  errorName    String?
  errorMessage String?
  errorStack   String?
  createdAt    DateTime @default(now())

  @@index([level, createdAt])
  @@index([event, createdAt])
  @@index([requestId])
  @@index([userId, createdAt])
  @@index([mediaId, createdAt])
  @@index([jobId])
  @@index([createdAt])
}
